{
  "name": "zero-core",
  "version": "0.1.0",
  "description": "Custom agent core based on Pi Agent with configurable extensions and OpenClaw harness integration",
  "type": "module",
  "bin": {
    "zero-core": "./dist/cli.js"
  },
  "main": "./out/main/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extension": {
      "types": "./dist/extension/index.d.ts",
      "import": "./dist/extension/index.js"
    },
    "./openclaw": {
      "types": "./dist/openclaw/plugin-entry.d.ts",
      "import": "./dist/openclaw/plugin-entry.js"
    }
  },
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "npm run build:lib && electron-vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "preview": "electron-vite preview",
    "build:lib": "tsc -p tsconfig.cli.json"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.77",
    "@ai-sdk/google": "^3.0.73",
    "@ai-sdk/openai": "^3.0.63",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^6.0.180",
    "better-sqlite3": "^12.10.0",
    "jsdom": "^29.1.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "turndown": "^7.2.4",
    "typebox": "^1.1.24",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "41.6.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
