{
  "name": "zero-core",
  "version": "0.1.0",
  "description": "Custom agent core based on Pi Agent with configurable extensions and OpenClaw harness integration",
  "type": "module",
  "bin": {
    "zero-core": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./extension": {
      "types": "./dist/extension/index.d.ts",
      "import": "./dist/extension/index.js"
    },
    "./openclaw": {
      "types": "./dist/openclaw/plugin-entry.d.ts",
      "import": "./dist/openclaw/plugin-entry.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.cli.json",
    "build:server": "tsc -p tsconfig.cli.json",
    "dev": "npx vite --config vite.config.ts",
    "dev:server": "node --watch dist/serve.js",
    "dev:full": "concurrently \"npm run build -- --watch\" \"npm run dev:server\"",
    "serve": "node dist/serve.js",
    "start": "node dist/serve.js"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "^0.73.0",
    "@mariozechner/pi-ai": "^0.73.0",
    "@mariozechner/pi-coding-agent": "^0.73.0",
    "express": "^5.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typebox": "^1.1.24",
    "uuid": "^14.0.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.7.3",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
