# zero-core 环境变量示例
#
# 用法:复制为 .env(已 gitignore)按需填入。所有变量可选 —— 不设走默认。
# 仅列适合用户或测试显式配置的项目变量；PATH、HOME、APPIMAGE 等运行时/系统变量不在此重复。桌面后端的 provider 主要在 Settings 配置；
# CLI 入口还会读取下方三种 API key,用于补全已存在的 system provider。

# ─── 数据目录 ───────────────────────────────────────────────
# zero-core 数据根(sessions.db、wiki、skills、attachments 等)。
# 默认: ~/.zero-core
# ZERO_CORE_DIR=/path/to/.zero-core

# ─── 调试 ───────────────────────────────────────────────────
# =1 打开 debug 级别日志(文件 + 控制台)。
# ZERO_CORE_DEBUG=1

# ─── 代理(企业防火墙/Brave Search/provider 走代理)──────────
# Node fetch 默认不读系统代理;这里显式开启。
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890

# ─── 后端端口 ───────────────────────────────────────────────
# 后端 Express 端口。Electron 模式下主进程用 --port=0 随机分配,本变量仅 CLI/
# 独立运行时生效。默认 3210。
# PORT=3210

# 独立 startServer 托管的 renderer 静态目录。Electron 桌面模式不使用。
# RENDERER_DIR=/path/to/out/renderer

# ─── Node 标准 ──────────────────────────────────────────────
# production / development。
# NODE_ENV=development

# ─── CLI Provider 补全 ─────────────────────────────────────
# 仅 src/cli.ts 的 autoConfigureFromEnv() 使用。桌面应用仍以 Settings / DB 配置为准。
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# ─── 仅测试用(普通使用勿设)─────────────────────────────────
# E2E fixture JSON 的绝对路径；设置后启用 mock provider 与 test seed。
# ZERO_CORE_TEST_FIXTURE=/absolute/path/to/fixture.json

# =1 禁用 WAL，使用 MEMORY journal。Vitest 隔离临时数据库时使用。
# ZERO_CORE_DB_NO_WAL=1

# =1 运行默认跳过的真实 Provider E2E；会产生真实 API 调用与费用。
# ZERO_CORE_E2E_REAL_API=1
