{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/cli.ts",
    "src/serve.ts",
    "src/index.ts",
    "src/core/**/*.ts",
    "src/extension/**/*.ts",
    "src/openclaw/**/*.ts",
    "src/server/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "out"]
}
